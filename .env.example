# Copy to .env and fill in. Never commit the real .env.

# --- Email (Gmail / Google Workspace) ---
# For keyahomes.in Workspace: create an App Password at
# https://myaccount.google.com/apppasswords (needs 2-Step Verification on).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=shashank@keyahomes.in
SMTP_PASS=your-16-char-app-password
MAIL_TO=shashank@keyahomes.in
MAIL_FROM=shashank@keyahomes.in

# --- Tuning (optional) ---
# ALWAYS_EMAIL=1   # 1 = email every run, 0 = email only when there are issues
# SLOW_MS=12000    # flag full page load slower than this (ms)
# TTFB_SLOW_MS=4000
# CONCURRENCY=1    # keep at 1 for accurate speed numbers
